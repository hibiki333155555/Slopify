{
  "name": "@slopify/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:main": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 file:dist/main/main.js && ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron dist/main/main.js",
    "dev:desktop": "concurrently -k \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "build:all": "npm run build && npm run build:renderer",
    "dist": "npm run build:all && electron-builder",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:linux": "npm run build:all && electron-builder --linux"
  },
  "dependencies": {
    "@slopify/shared": "file:../../packages/shared",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.34.1",
    "marked": "^17.0.4",
    "socket.io-client": "^4.8.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.2.1",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "wait-on": "^8.0.5",
    "zustand": "^4.5.5"
  }
}
